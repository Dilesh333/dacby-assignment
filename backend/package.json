{
  "name": "hackernews-backend",
  "version": "1.0.0",
  "description": "Production-ready Express + MongoDB backend for HackerNews MERN app",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "echo \"Add eslint here if needed\""
  },
  "nodemonConfig": {
    "watch": ["."],
    "ext": "js,json",
    "ignore": ["node_modules/", "*.test.js"],
    "delay": "500"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
